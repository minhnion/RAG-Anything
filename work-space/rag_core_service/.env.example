# RAG Core Service
RAG_CORE_HOST=0.0.0.0
RAG_CORE_PORT=7220
RAG_CORE_DATA_DIR=./.local-data
RAG_CORE_PUBLIC_BASE_URL=
# Optional bearer token for internal service-to-service calls.
RAG_CORE_SERVICE_TOKEN=
RAG_CORE_LOG_DIR=./.local-data/logs
RAG_CORE_LOG_LEVEL=INFO
RAG_CORE_LOG_MAX_BYTES=10485760
RAG_CORE_LOG_BACKUP_COUNT=10

# Default quality profile selected from the experiments.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-large
OPENAI_EMBED_DIM=3072

# Optional local/cost fallback profile.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_LLM_MODEL=
OLLAMA_VISION_MODEL=
OLLAMA_EMBED_MODEL=
OLLAMA_EMBED_DIM=768

# MinerU cloud parser.
MINERU_API_KEY=
MINERU_API_BASE_URL=https://mineru.net

